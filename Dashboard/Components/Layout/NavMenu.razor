@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inherits LocalizedComponentBase

<header>
    <nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="dark">
        <div class="container-fluid">
            <div class="navbar-brand" href="/">Joris Reynes</div>

            <button class="navbar-toggler" type="button" id="navToggleBtn"
                    aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <!-- Liens gauche -->
                <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                    <li class="nav-item"><a class="nav-link" href="/cv">CV</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Websites">Websites</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Articles">Articles</a></li>
                    <li class="nav-item"><a class="nav-link" href="/job-data">Job Data</a></li>
                </ul>

                <!-- Liens droite -->
                <ul class="navbar-nav ms-auto align-items-center">

                    <!-- Sélecteur de langue -->
                    <li class="nav-item d-flex align-items-center gap-1 me-2">
                        <LanguageSwitcher />
                    </li>

                    <AuthorizeView Context="auth">
                        <Authorized>
                            @if (auth.User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" href="/quiz">@Language.Translate("Questions Techniques", "Technical Questions")</a></li>
                                <li class="nav-item"><a class="nav-link" href="/coding/singleton">@Language.Translate("Défis Coding", "Coding Challenges")</a></li>
                            }

                            @{
                                var userName = auth.User.Identity?.Name ?? "(utilisateur)";
                            }

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    @userName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="/Account/Register">@Language.Translate("Inscription", "Register")</a></li>
                                    <li>
                                        <form method="post" action="/Account/Logout" @formname="logout-form" data-enhance="false">
                                            <button type="submit" class="dropdown-item">@Language.Translate("Déconnexion", "Logout")</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        </Authorized>

                        <NotAuthorized>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Account/Login">@Language.Translate("Connexion", "Login")</a>
                            </li>
                        </NotAuthorized>
                    </AuthorizeView>
                </ul>
            </div>
        </div>
    </nav>
</header>

