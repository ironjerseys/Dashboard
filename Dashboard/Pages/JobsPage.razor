@page "/job-data"

@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Dashboard.Services

@inherits LocalizedComponentBase
@inject IJobPostingService JobService
@inject IJSRuntime JS

@rendermode RenderMode.InteractiveServer

<div class="mb-4">
    <h1 class="mb-1">@Language.Translate("Offres d'emploi", "Job Listings")</h1>
    <p class="text-muted mb-0">@Language.Translate("Aperçu du marché, actualisé chaque semaine.", "Live market overview, refreshed weekly.")</p>
</div>

    @if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_busy)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">@Language.Translate("Chargement des stats…", "Loading stats…")</p>
        </div>
    }
    else if (_stats is null || _stats.TotalCount == 0)
    {
        <div class="alert alert-info">
            @Language.Translate("Aucune offre en base. Le scraper tourne tous les dimanches à 3h UTC.",
                  "No listings in the database. The scraper runs every Sunday at 3 AM UTC.")<br />
            @Language.Translate("Pour lancer manuellement :", "To run manually:")&nbsp;<code>docker compose exec jobspy python /app/scrape_jobs.py</code>
        </div>
    }
    else
    {
        <!-- KPI strip -->
        <div class="stat-bar mb-4">
            <div class="stat-bar-item accent">
                <i class="bi bi-briefcase stat-bar-icon"></i>
                <div>
                    <div class="stat-bar-num">@_stats.TotalCount.ToString("N0")</div>
                    <div class="stat-bar-label">@Language.Translate("Offres totales", "Total listings")</div>
                </div>
            </div>
            <div class="stat-bar-item">
                <i class="bi bi-house-door stat-bar-icon"></i>
                <div>
                    <div class="stat-bar-num">@RemotePct%</div>
                    <div class="stat-bar-label">Remote</div>
                </div>
            </div>
            <div class="stat-bar-item">
                <i class="bi bi-tags stat-bar-icon"></i>
                <div>
                    <div class="stat-bar-num">@_stats.ByRole.Count</div>
                    <div class="stat-bar-label">@Language.Translate("Rôles suivis", "Tracked roles")</div>
                </div>
            </div>
            <div class="stat-bar-item">
                <i class="bi bi-clock-history stat-bar-icon"></i>
                <div>
                    <div class="stat-bar-num" style="font-size:1.15rem;">@(_stats.LastScrapeAt?.ToString("dd/MM/yyyy") ?? "—")</div>
                    <div class="stat-bar-label">@Language.Translate("Dernier scraping", "Last scrape")</div>
                </div>
            </div>
        </div>

        <!-- Charts row 1 -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">@Language.Translate("Offres par rôle", "Listings by role")</div>
                    <div class="card-body">
                        <canvas id="roleChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">@Language.Translate("Offres par ville", "Listings by city")</div>
                    <div class="card-body">
                        <canvas id="cityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts row 2 -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-header">@Language.Translate("Répartition par site", "Distribution by source")</div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <div style="width:100%;max-width:220px;">
                            <canvas id="siteChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card h-100">
                    <div class="card-header">@Language.Translate("Évolution (par run de scraping)", "Trend (by scraping run)")</div>
                    <div class="card-body">
                        <canvas id="weekChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts row 3 : rôle × ville -->
        <div class="row g-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">@Language.Translate("Offres par rôle et par ville", "Listings by role and city")</div>
                    <div class="card-body" style="height: @($"{Math.Max(280, _stats.ByCity.Count * _stats.ByRole.Count * 22 + 60)}px")">
                        <canvas id="roleCityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }



@code {
    private bool _busy;
    private string? _error;
    private JobStats? _stats;
    private bool _chartsDrawn;

    private int RemotePct => _stats is { TotalCount: > 0 }
        ? (int)Math.Round(_stats.RemoteCount * 100.0 / _stats.TotalCount)
        : 0;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Language.OnChange += OnLangChange;
    }

    private void OnLangChange() => _chartsDrawn = false;

    public override void Dispose()
    {
        Language.OnChange -= OnLangChange;
        base.Dispose();
    }

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_stats is { TotalCount: > 0 } && !_chartsDrawn)
        {
            _chartsDrawn = true;
            await DrawChartsAsync();
        }
    }

    private async Task ReloadAsync()
    {
        _busy = true;
        _error = null;
        _chartsDrawn = false;
        StateHasChanged();

        try
        {
            _stats = await JobService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DrawChartsAsync()
    {
        if (_stats is null) return;

        await JS.InvokeVoidAsync("JobCharts.bar",
            "roleChart",
            _stats.ByRole.Select(x => x.Label).ToArray(),
            _stats.ByRole.Select(x => x.Count).ToArray(),
            Language.Translate("Offres", "Listings"));

        await JS.InvokeVoidAsync("JobCharts.bar",
            "cityChart",
            _stats.ByCity.Select(x => x.Label).ToArray(),
            _stats.ByCity.Select(x => x.Count).ToArray(),
            Language.Translate("Offres", "Listings"));

        await JS.InvokeVoidAsync("JobCharts.doughnut",
            "siteChart",
            _stats.BySite.Select(x => x.Label).ToArray(),
            _stats.BySite.Select(x => x.Count).ToArray());

        await JS.InvokeVoidAsync("JobCharts.line",
            "weekChart",
            _stats.ByWeek.Select(x => x.Label).ToArray(),
            _stats.ByWeek.Select(x => x.Count).ToArray(),
            Language.Translate("Nouvelles offres", "New listings"));

        var cities = _stats.ByCity.Select(x => x.Label).ToList();
        var roles = _stats.ByRole.Select(x => x.Label).ToList();
        var lookup = _stats.ByRoleCity.ToDictionary(x => (x.Role, x.City), x => x.Count);
        var datasets = roles.Select(role => new
        {
            label = role,
            data = cities.Select(city => lookup.TryGetValue((role, city), out var c) ? c : 0).ToArray()
        }).ToArray();

        await JS.InvokeVoidAsync("JobCharts.groupedBar", "roleCityChart", cities.ToArray(), datasets);
    }
}
