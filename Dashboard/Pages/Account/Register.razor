@page "/account/register"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components

@inherits LocalizedComponentBase
@attribute [Authorize]
@rendermode RenderMode.InteractiveServer

<PageTitle>@Language.Translate("Inscription", "Register")</PageTitle>

<div class="container mt-3 mt-md-4">
    <h1 class="mb-3">@Language.Translate("Inscription", "Register")</h1>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    <form method="post" action="/Account/Register" class="mt-3" data-enhance="false">
        <div class="mb-3">
            <label class="form-label" for="Email">Email</label>
            <input id="Email" name="Email" class="form-control"
                   value="@Email" autocomplete="username" required />
        </div>

        <div class="mb-3">
            <label class="form-label" for="Password">@Language.Translate("Mot de passe", "Password")</label>
            <input id="Password" name="Password" type="password"
                   class="form-control" autocomplete="new-password" required />
        </div>

        <button type="submit" class="btn btn-primary">@Language.Translate("Créer le compte", "Create account")</button>
    </form>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _errorMessage = Error switch
        {
            "required" => Language.Translate("Email et mot de passe requis.", "Email and password are required."),
            "failed"   => Language.Translate("Impossible de créer le compte (mot de passe trop faible ou email déjà utilisé).",
                               "Unable to create account (password too weak or email already in use)."),
            _ => null
        };
    }
}
