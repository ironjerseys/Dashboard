@page "/account/accessdenied"

@using Microsoft.AspNetCore.Components.Web

@inherits LocalizedComponentBase
@rendermode RenderMode.InteractiveServer

<PageTitle>@Language.Translate("Accès refusé", "Access Denied")</PageTitle>

<div class="container mt-5 article-page">
    <h1 class="mb-3">@Language.Translate("Accès refusé", "Access Denied")</h1>
    <p>@Language.Translate("Vous n'avez pas les droits pour accéder à cette page.", "You don't have permission to access this page.")</p>
    <a class="btn btn-secondary" href="/">@Language.Translate("Retour", "Back")</a>
</div>
