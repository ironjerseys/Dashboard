@page "/cv"

@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@using global::Dashboard.Models

@inherits LocalizedComponentBase
@inject IJSRuntime JS

@rendermode RenderMode.InteractiveServer

<div class="container mt-3 mt-md-4">
    @{
        var index = 0;
    }

    @foreach (var exp in Experiences)
    {
        <article class="exp-item afficher py-4" data-index="@index">
            <div class="d-flex gap-3 align-items-start">

                @if (!string.IsNullOrWhiteSpace(exp.LogoUrl))
                {
                    <img class="exp-logo"
                         src="@exp.LogoUrl"
                         alt="@($"{exp.Entreprise} logo")"
                         loading="lazy" />
                }

                <div class="flex-grow-1">
                    <header class="d-flex flex-column flex-md-row justify-content-between gap-2">
                        <div>
                            <h2 class="exp-title mb-1">@exp.Titre</h2>
                            <div class="exp-meta">
                                <span class="exp-company">@exp.Entreprise</span>
                                <span class="exp-sep">•</span>
                                <span class="exp-period">@Language.Translate("Période :", "Period:") @exp.Periode</span>
                            </div>
                        </div>
                    </header>

                    <div class="exp-body mt-3">
                        @((MarkupString)exp.Description)
                    </div>

                    @if (exp.Technos?.Any() ?? false)
                    {
                        <div class="exp-tags mt-3">
                            @foreach (var techno in exp.Technos)
                            {
                                <span class="@GetTechClass(techno)">@techno</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </article>

        index++;
    }
</div>

