@page "/websites"

@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@using global::Dashboard.Models

@inherits LocalizedComponentBase
@inject IJSRuntime JS

@rendermode RenderMode.InteractiveServer

<div class="container mt-3 mt-md-4">
    @foreach (var website in WebsitesList)
    {
        var isRemoved = string.IsNullOrWhiteSpace(website.Url);

        <div class="exp-item p-3 p-md-4 afficher @(isRemoved ? "removed" : "")">

            <header class="d-flex flex-column flex-md-row justify-content-between gap-2 mt-3 mb-3 mt-md-5 mb-md-4">
                <div>
                    <h2 class="exp-title mb-1">@website.Name</h2>

                    <div class="exp-meta">
                        @if (!isRemoved)
                        {
                            <span class="exp-company">@Language.Translate("Disponible sur :", "Available on:") </span>
                            <a class="site-link" href="@website.Url" target="_blank" rel="noopener noreferrer">
                                @website.Platform
                            </a>
                        }
                        else
                        {
                            <span class="exp-company">@Language.Translate("Intégré à ChessMultitool", "Merged into ChessMultitool")</span>
                        }
                    </div>
                </div>
            </header>

            <img src="@($"/images/{website.Image}")" alt="@website.Name" class="site-image" />
            <div class="mt-3 mt-md-5 mb-3 mb-md-4">@((MarkupString)website.DescriptionHtml)</div>
        </div>
    }
</div>

@code {
    private IReadOnlyList<Website> WebsitesList => new List<Website>
    {
        new Website
        {
            Name = "Chess Multitool",
            DescriptionHtml = Language.Translate(
                "<p>J'ai transformé Chess Results Stats en Chess Multitool, une application mobile sur Google Play dans un premier temps, avec quelques features supplémentaires.</p>" +
                "<p>J'ai développé l'application avec .NET MAUI.</p>" +
                "<p>Mon but est de développer mes compétences en développement mobile pour savoir créér une app, la déployer sur un store d'applications, et la monétiser.</p>",
                "<p>I transformed Chess Results Stats into Chess Multitool, a mobile app available on Google Play with additional features.</p>" +
                "<p>I built the app using .NET MAUI.</p>" +
                "<p>My goal was to develop my mobile development skills: from building an app to deploying it on a store and monetizing it.</p>"),
            Url = "https://play.google.com/store/apps/details?id=com.companyname.chessmultitool&hl=en",
            Platform = "Play Store",
            Image = "chessmultitool.png"
        },
        new Website
        {
            Name = "Chess Results Stats",
            DescriptionHtml = Language.Translate(
                "<p>Chess Results Stats est un site pour analyser des données fournies par Chess.com, le site d'échec en ligne le plus utilisé dans le monde.</p>" +
                "<p>Il part d'un projet scolaire où je devais manipuler des données avec LinQ, je l'ai donc réalisé en .NET et Angular, j'ai stocké le code sur GitHub et j'ai déployé le site sur Azure avec une pipeline CI/CD GitHub Actions.</p>" +
                "<p>J'ai profité de ce projet pour tester différentes stacks techniques, j'ai refait le projet avec la MERN stack, MongoDB Express React et Node.JS.</p>" +
                "<p>La première version consistait à exporter un fichier de Chess.com et l'uploader sur mon site, pour visualiser quelques résultats clés. Avec la deuxième version j'ai ajouté une base de donnée pour stocker les résultats, remplacé les quelques résultats clés par des graphs avec Chart.JS et remplacé le download/upload de fichier par un appel à l'API Chess.com.</p>" +
                "<p>J'ai ensuite réécris le site en Java / Angular, pour enfin revenir à .NET / Angular, et j'ai remplacé la base de donnée MongoDB par une base de donnée SQL Server hébergée sur Azure.</p>",
                "<p>Chess Results Stats is a site for analyzing data provided by Chess.com, the world's most popular online chess platform.</p>" +
                "<p>It started as a school project where I needed to work with LINQ. I built it with .NET and Angular, hosted the code on GitHub, and deployed on Azure with a CI/CD GitHub Actions pipeline.</p>" +
                "<p>I used this project to experiment with different tech stacks, rebuilding it with the MERN stack (MongoDB, Express, React, Node.js).</p>" +
                "<p>The first version let users export a file from Chess.com and upload it to visualize a few key metrics. The second version added a database to store results, replaced the basic stats with Chart.js graphs, and replaced file upload with a direct Chess.com API call.</p>" +
                "<p>I later rewrote the site in Java / Angular, then came back to .NET / Angular, and replaced MongoDB with SQL Server hosted on Azure.</p>"),
            Url = "",
            Platform = "",
            Image = "chessresultsstats.png"
        },
        new Website
        {
            Name = "C'est quoi l'ouverture",
            DescriptionHtml = Language.Translate(
                "<p>C'est quoi l'ouverture est un site permettant de visualiser les ouvertures les plus connues et quelques pièges d'ouverture. J'ai développé le site en Python avec Django, un framework que je voulais découvrir depuis longtemps, et une base de données PostgreSQL.</p>" +
                "<p>Le code est sur GitHub et le site est déployé sur Azure avec une pipeline CI/CD GitHub Actions.</p>",
                "<p>C'est quoi l'ouverture is a site to visualize the most well-known chess openings and common opening traps. I built it in Python with Django, a framework I had been eager to explore, backed by a PostgreSQL database.</p>" +
                "<p>The code is on GitHub and the site is deployed on Azure with a CI/CD GitHub Actions pipeline.</p>"),
            Url = "",
            Platform = "",
            Image = "cestquoilouverture.png"
        }
    };
}
