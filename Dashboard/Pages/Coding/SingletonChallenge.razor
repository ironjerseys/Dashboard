@page "/coding/singleton"

@using System.Security.Claims
@using Dashboard.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web

@* @attribute [Authorize]
 *@

@rendermode RenderMode.InteractiveServer

@inject CodeChallengeService ChallengeService
@inject ICodeChallengeReviewService ReviewService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Challenge: Singleton Pattern</PageTitle>

<div class="container-lg py-4">

    <div class="mb-4">
        <h1 class="mb-1">Challenge: Singleton Pattern</h1>
        <p class="text-muted mb-0">Implement the <code>Singleton</code> class then click <strong>Validate</strong> — your code will be compiled and tested live.</p>
    </div>

    @if (_isAuthenticated && _card is not null)
    {
        <div class="card p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="text-muted small">
                    Box @_card.Box
                    @if (_card.IsDue)
                    {
                        <span class="badge bg-warning text-dark ms-2">Due today</span>
                    }
                </span>
                <span class="text-muted small">
                    Due: @_card.NextDueDate.ToString("yyyy-MM-dd")
                </span>
            </div>
        </div>
    }

    <!-- Theory reminder -->
    <div class="card p-3 mb-4">
        <div class="fw-semibold mb-2">What is a Singleton?</div>
        <ul class="mb-0 ps-3">
            <li>Only one instance of the class exists throughout the entire application.</li>
            <li>The constructor is <strong>private</strong> — the class cannot be instantiated with <code>new</code>.</li>
            <li>Access is provided via a static method <code>GetInstance()</code>.</li>
            <li>Ideally <strong>thread-safe</strong>: if two threads call <code>GetInstance()</code> simultaneously, they get the same instance.</li>
        </ul>
    </div>

    <!-- Hints -->
    <details class="mb-4">
        <summary class="fw-semibold" style="cursor:pointer;">Hints (click to show)</summary>
        <ol class="mt-2 ps-3">
            <li>Declare a field <code>private static Singleton? _instance;</code></li>
            <li>In <code>GetInstance()</code>, check whether <code>_instance</code> is null and create it if needed.</li>
            <li>For thread-safety, use <code>lock</code> or <code>Lazy&lt;T&gt;</code>.</li>
        </ol>
    </details>

    <!-- Code editor -->
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <label class="fw-semibold mb-0">Your C# code</label>
            <button class="btn btn-sm btn-outline-secondary" @onclick="Reset" disabled="@_busy">
                Reset
            </button>
        </div>
        <textarea class="form-control font-monospace"
                  rows="18"
                  spellcheck="false"
                  autocomplete="off"
                  autocorrect="off"
                  autocapitalize="off"
                  style="font-size:.88rem;resize:vertical;tab-size:4;"
                  @bind="_code"
                  @bind:event="oninput"
                  disabled="@_busy"></textarea>
    </div>

    <div class="d-flex gap-2 align-items-center mb-4">
        <button class="btn" @onclick="ValidateAsync" disabled="@_busy">
            @if (_busy)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                <span>Compiling…</span>
            }
            else
            {
                <span>Validate code</span>
            }
        </button>
    </div>

    <!-- Unexpected error -->
    @if (_unexpectedError is not null)
    {
        <div class="alert alert-danger">
            <strong>Unexpected error:</strong> @_unexpectedError
        </div>
    }

    <!-- Results -->
    @if (_result is not null)
    {
        <div class="card p-3">
            <div class="fw-semibold mb-3">Results</div>

            @if (_result.HasCompileError)
            {
                <div class="alert alert-danger mb-0">
                    <div class="fw-semibold mb-1">Compilation error</div>
                    <pre class="mb-0" style="font-size:.82rem;white-space:pre-wrap;">@_result.CompileErrors</pre>
                </div>
            }
            else
            {
                var allPassed = _result.TestResults.All(r => r.Passed);

                @foreach (var test in _result.TestResults)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        @if (test.Passed)
                        {
                            <span class="text-success fw-bold flex-shrink-0">&#10003;</span>
                            <span>@test.Message</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold flex-shrink-0">&#10007;</span>
                            <span class="text-danger">@test.Message</span>
                        }
                    </div>
                }

                <hr class="my-3" />

                @if (allPassed)
                {
                    <div class="alert alert-success mb-0 fw-semibold">
                        All tests passed — your Singleton is correct!
                        @if (_isAuthenticated && _card is not null)
                        {
                            <div class="fw-normal small mt-1">
                                Next review: @_card.NextDueDate.ToString("yyyy-MM-dd") (box @_card.Box).
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        Some tests failed. Review the hints and try again.
                    </div>
                }
            }
        </div>
    }

</div>

@code {
    private static readonly string Template =
        "public class Singleton\n" +
        "{\n" +
        "    // 1. Declare the private static field that holds the unique instance\n" +
        "\n" +
        "    // 2. The constructor must be private\n" +
        "    private Singleton() { }\n" +
        "\n" +
        "    // 3. Implement GetInstance(): must always return the same instance\n" +
        "    public static Singleton GetInstance()\n" +
        "    {\n" +
        "        // TODO: your implementation here\n" +
        "        throw new NotImplementedException();\n" +
        "    }\n" +
        "}";

    private const string ChallengeKey = "singleton";

    private string _code = Template;
    private bool _busy;
    private ChallengeRunResult? _result;
    private string? _unexpectedError;

    // ── Répétition espacée (Leitner), comme les questions techniques ──
    private bool _isAuthenticated;
    private string _userId = string.Empty;
    private CodeChallengeCardInfo? _card;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        if (_isAuthenticated && !string.IsNullOrWhiteSpace(_userId))
        {
            try
            {
                _card = await ReviewService.GetOrCreateCardAsync(
                    _userId, ChallengeKey, DateOnly.FromDateTime(DateTime.UtcNow));
            }
            catch { /* l'affichage de la due date est optionnel */ }
        }
    }

    private async Task ValidateAsync()
    {
        _busy = true;
        _result = null;
        _unexpectedError = null;
        try
        {
            _result = await ChallengeService.ValidateSingletonAsync(_code);
            await RecordReviewIfDueAsync();
        }
        catch (Exception ex)
        {
            _unexpectedError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RecordReviewIfDueAsync()
    {
        // On n'enregistre une tentative que si la carte est due aujourd'hui,
        // pour ne pas gonfler la boîte en cliquant plusieurs fois sur Validate.
        if (!_isAuthenticated || string.IsNullOrWhiteSpace(_userId) || _result is null) return;
        if (_card is null || !_card.IsDue) return;
        if (_result.HasCompileError) return;
        if (_result.TestResults.Count == 0) return;

        bool allPassed = _result.TestResults.All(r => r.Passed);
        _card = await ReviewService.RecordReviewAsync(
            _userId, ChallengeKey, allPassed, DateOnly.FromDateTime(DateTime.UtcNow));
    }

    private void Reset()
    {
        _code = Template;
        _result = null;
    }
}
