@page "/coding/two-sum"

@using System.Security.Claims
@using Dashboard.Components.Coding
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web

@rendermode RenderMode.InteractiveServer

@inject CodeChallengeService ChallengeService
@inject ICodeChallengeReviewService ReviewService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Challenge: Two Sum</PageTitle>

<div class="container-lg py-4">

    <div class="mb-4">
        <a href="/coding" class="back-button">
            <i class="bi bi-arrow-left"></i>
            <span>Coding Challenges</span>
        </a>
    </div>

    <div class="mb-4">
        <h1 class="mb-1">Challenge: Two Sum</h1>
        <p class="text-muted mb-0">A classic interview warm-up. Implement <code>TwoSum</code> then click <strong>Validate</strong> — your code is compiled and tested live.</p>
    </div>

    @if (_isAuthenticated && _card is not null)
    {
        <div class="card p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="text-muted small">
                    Box @_card.Box
                    @if (_card.IsDue)
                    {
                        <span class="badge bg-warning text-dark ms-2">Due today</span>
                    }
                </span>
                <span class="text-muted small">
                    Due: @_card.NextDueDate.ToString("yyyy-MM-dd")
                </span>
            </div>
        </div>
    }

    <!-- Problem statement -->
    <div class="card p-3 mb-4">
        <div class="fw-semibold mb-2">The problem</div>
        <ul class="mb-0 ps-3">
            <li>Given an array of integers <code>nums</code> and an integer <code>target</code>, return the <strong>indices</strong> of the two numbers that add up to <code>target</code>.</li>
            <li>Each input has <strong>exactly one</strong> solution, and you may not use the same element twice.</li>
            <li>The two indices may be returned in any order.</li>
            <li>Example: <code>nums = [2, 7, 11, 15]</code>, <code>target = 9</code> → <code>[0, 1]</code> (because 2 + 7 = 9).</li>
        </ul>
    </div>

    <!-- Hints -->
    <details class="mb-4">
        <summary class="fw-semibold" style="cursor:pointer;">Hints (click to show)</summary>
        <ol class="mt-2 ps-3">
            <li>The brute-force solution uses two nested loops — O(n²).</li>
            <li>For O(n), keep a <code>Dictionary&lt;int, int&gt;</code> mapping each value to its index.</li>
            <li>For each number, check whether <code>target - num</code> is already in the dictionary.</li>
        </ol>
    </details>

    <!-- Code editor -->
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <label class="fw-semibold mb-0">Your C# code</label>
            <button class="btn btn-sm btn-outline-secondary" @onclick="Reset" disabled="@_busy">
                Reset
            </button>
        </div>
        <CodeEditor @bind-Value="_code" Rows="18" Disabled="_busy" />
    </div>

    <div class="d-flex gap-2 align-items-center mb-4">
        <button class="btn" @onclick="ValidateAsync" disabled="@_busy">
            @if (_busy)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                <span>Compiling…</span>
            }
            else
            {
                <span>Validate code</span>
            }
        </button>
    </div>

    @if (_unexpectedError is not null)
    {
        <div class="alert alert-danger">
            <strong>Unexpected error:</strong> @_unexpectedError
        </div>
    }

    @if (_result is not null)
    {
        <div class="card p-3">
            <div class="fw-semibold mb-3">Results</div>

            @if (_result.HasCompileError)
            {
                <div class="alert alert-danger mb-0">
                    <div class="fw-semibold mb-1">Compilation error</div>
                    <pre class="mb-0" style="font-size:.82rem;white-space:pre-wrap;">@_result.CompileErrors</pre>
                </div>
            }
            else
            {
                var allPassed = _result.TestResults.All(r => r.Passed);

                @foreach (var test in _result.TestResults)
                {
                    <div class="d-flex align-items-start gap-2 mb-2">
                        @if (test.Passed)
                        {
                            <span class="text-success fw-bold flex-shrink-0">&#10003;</span>
                            <span>@test.Message</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold flex-shrink-0">&#10007;</span>
                            <span class="text-danger">@test.Message</span>
                        }
                    </div>
                }

                <hr class="my-3" />

                @if (allPassed)
                {
                    <div class="alert alert-success mb-0 fw-semibold">
                        All tests passed — your Two Sum is correct!
                        @if (_isAuthenticated && _card is not null)
                        {
                            <div class="fw-normal small mt-1">
                                Next review: @_card.NextDueDate.ToString("yyyy-MM-dd") (box @_card.Box).
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        Some tests failed. Review the hints and try again.
                    </div>
                }
            }
        </div>
    }

</div>

@code {
    private static readonly string Template =
        "public class Solution\n" +
        "{\n" +
        "    // Return the indices of the two numbers that add up to target.\n" +
        "    public int[] TwoSum(int[] nums, int target)\n" +
        "    {\n" +
        "        // TODO: your implementation here\n" +
        "        throw new NotImplementedException();\n" +
        "    }\n" +
        "}";

    private const string ChallengeKey = "two-sum";

    private string _code = Template;
    private bool _busy;
    private ChallengeRunResult? _result;
    private string? _unexpectedError;

    private bool _isAuthenticated;
    private string _userId = string.Empty;
    private CodeChallengeCardInfo? _card;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAuthenticated = user.Identity?.IsAuthenticated ?? false;
        _userId = user.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        if (_isAuthenticated && !string.IsNullOrWhiteSpace(_userId))
        {
            try
            {
                _card = await ReviewService.GetOrCreateCardAsync(
                    _userId, ChallengeKey, DateOnly.FromDateTime(DateTime.UtcNow));
            }
            catch { /* due date display is optional */ }
        }
    }

    private async Task ValidateAsync()
    {
        _busy = true;
        _result = null;
        _unexpectedError = null;
        try
        {
            _result = await ChallengeService.ValidateTwoSumAsync(_code);
            await RecordReviewIfDueAsync();
        }
        catch (Exception ex)
        {
            _unexpectedError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RecordReviewIfDueAsync()
    {
        if (!_isAuthenticated || string.IsNullOrWhiteSpace(_userId) || _result is null) return;
        if (_card is null || !_card.IsDue) return;
        if (_result.HasCompileError) return;
        if (_result.TestResults.Count == 0) return;

        bool allPassed = _result.TestResults.All(r => r.Passed);
        _card = await ReviewService.RecordReviewAsync(
            _userId, ChallengeKey, allPassed, DateOnly.FromDateTime(DateTime.UtcNow));
    }

    private void Reset()
    {
        _code = Template;
        _result = null;
    }
}
