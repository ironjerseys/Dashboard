@page "/coding"

@using Microsoft.AspNetCore.Components.Web

@rendermode RenderMode.InteractiveServer

@inject NavigationManager Navigation

<PageTitle>Coding Challenges</PageTitle>

<div class="container-lg py-4">

    <div class="mb-3">
        <a href="/quiz/all" class="text-decoration-none small">&larr; Technical Questions</a>
    </div>

    <div class="mb-4">
        <h1 class="mb-1">Coding Challenges</h1>
        <p class="text-muted mb-0">Pick a challenge. Your code is compiled and tested live, with instant feedback.</p>
    </div>

    <div class="row g-3">
        @foreach (var c in Challenges)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <button type="button" class="card p-3 text-start border-0 shadow-sm h-100 w-100"
                        style="cursor:pointer;"
                        @onclick="() => Navigation.NavigateTo(c.Href)">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi @c.Icon fs-5"></i>
                        <span class="fw-semibold">@c.Title</span>
                    </div>
                    <div class="text-muted small">@c.Description</div>
                </button>
            </div>
        }
    </div>

</div>

@code {
    private record ChallengeCard(string Title, string Description, string Href, string Icon);

    private static readonly ChallengeCard[] Challenges =
    {
        new("Singleton Pattern",
            "Implement a thread-safe singleton with a private constructor and a single shared instance.",
            "/coding/singleton", "bi-box"),
        new("Two Sum",
            "Return the indices of the two numbers that add up to a target. A classic interview warm-up.",
            "/coding/two-sum", "bi-plus-slash-minus"),
        new("Three Sum",
            "Find all unique triplets that sum to zero. A very common interview question.",
            "/coding/three-sum", "bi-collection"),
    };
}
